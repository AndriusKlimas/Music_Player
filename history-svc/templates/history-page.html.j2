<!DOCTYPE html>
<html>
<head>
    <title>Listening History - Music Player</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body {
            padding-top: 20px;
        }
        .history-item {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }
        .history-item:hover {
            background-color: #f8f9fa;
        }
        .no-history {
            text-align: center;
            padding: 50px;
            color: #999;
        }
    </style>
</head>
<body>

<div class="header">
<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <a class="navbar-brand" href="#">Listening History</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/get-catalog">View All Songs</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/add-product-page">Add Song</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/history-page">History</a>
                </li>
            </ul>
            <ul class="navbar-nav">
                {% if username %}
                <li class="nav-item">
                    <span class="navbar-text mr-3">Logged in as: <strong>{{ username }}</strong></span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/logout">Logout</a>
                </li>
                {% else %}
                <li class="nav-item">
                    <a class="nav-link" href="/login-page">Login</a>
                </li>
                {% endif %}
            </ul>
        </div>
    </nav>
</header>
</div>

<div class="container mt-4">
    <h2>Your Listening History</h2>
    
    {% if not username %}
    <div class="alert alert-warning mt-3">
        Please <a href="/login-page">login</a> to view your listening history.
    </div>
    {% elif history|length == 0 %}
    <div class="no-history">
        <h4>No listening history yet</h4>
        <p>Start playing some songs to see them here!</p>
        <a href="/get-catalog" class="btn btn-primary">Browse Songs</a>
    </div>
    {% else %}
    <div class="list-group mt-3">
        {% for item in history %}
        <div class="list-group-item history-item">
            <div class="d-flex w-100 justify-content-between">
                <h5 class="mb-1">🎵 {{ item.song_name }}</h5>
                <small>{{ item.timestamp }}</small>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>

<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
