<!DOCTYPE html>
<html>
<head>
    <title>Song Player</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        .song-card {
            margin-bottom: 20px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }
        audio {
            width: 100%;
        }
    </style>
</head>

<body>
<div class="header">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <a class="navbar-brand" href="#">Song Player</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav mr-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/get-catalog">View All Songs</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/add-product-page">Add Song</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>
</div>

<div class="container mt-4">

    {% if song %}
    <!-- SINGLE SONG VIEW: Display only the selected song -->
    <h2>Now Playing</h2>
    
    <div class="card song-card">
        <div class="card-body text-center">
            <!-- Song information -->
            <h4 class="card-title">{{ song.name }}</h4>
            <p class="card-text">
                <strong>Artist:</strong> {{ song.artist }}<br>
                <strong>Album:</strong> {{ song.album }}
            </p>
            
            <!-- Audio player - combines base URL + audio_mp3 filename -->
            {% if song.audio_mp3 %}
            <audio controls autoplay>
                <source src="{{ audio_base_url }}{{ song.audio_mp3 }}" type="audio/mpeg">
                Your browser does not support the audio element.
            </audio>
            <small class="text-muted d-block mt-2">
                File: {{ song.audio_mp3 }}
            </small>
            {% else %}
            <div class="alert alert-warning">
                No audio file available for this song.
            </div>
            {% endif %}
            
            <!-- Link back to song list -->
            <a href="/get-catalog" class="btn btn-secondary mt-3">Back to Song List</a>
        </div>
    </div>
    
    {% else %}
    <!-- SONG NOT FOUND: Show error message -->
    <div class="alert alert-warning">
        <h4>Song Not Found</h4>
        {% if audio_filename %}
        <p>Could not find song: <strong>{{ audio_filename }}</strong></p>
        {% endif %}
        <a href="/get-catalog" class="btn btn-primary">Back to Song List</a>
    </div>
    {% endif %}

</div>

<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
