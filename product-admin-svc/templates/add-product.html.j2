
<head>
    <title>Add Product</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>
<body>
<div class="header">
<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <a class="navbar-brand" href="#">Add new Song</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/get-catalog">View All Songs</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/add-product-page">Add Song</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/history-page">History</a>
                </li>
            </ul>
        </div>
    </nav>
</header>

</div>
    <div class="card">
        <div class="card-header">
            <h1>Add New Song</h1>
        </div>
        <div class="card-body">
            <form action="add-product" method="post" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="name">Song name:</label>
                    <input type="text" name="name" id="name" class="form-control">
                </div>
                <div class="form-group">
                    <label for="artist">Artist name:</label>
                    <input type="text" name="artist" id="artist" class="form-control">
                </div>
                <div class="form-group">
                    <label for="album">Song Album:</label>
                    <input type="text" name="album" id="album" class="form-control">
                </div>
                <div class="form-group">
                    <label for="audio_mp3">Audio MP3:</label>
                    <input type="file" name="audio_mp3" id="audio_mp3" class="form-control">
                </div>
                <button type="submit" class="btn btn-primary">Add Song</button>
            </form>
        </div>
    </div>
</body>
